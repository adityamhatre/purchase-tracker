# Port to run the server on (default: 8080)
PORT=8080

# Gmail label to filter purchase/receipt emails
GMAIL_LABEL_NAME=Purchases

# Google Cloud OAuth 2.0 Credentials (obtain from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback

# Google OAuth 2.0 Refresh Token (obtained after running the /auth/google flow)
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Google Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key

# Supabase Credentials (obtain from your Supabase Project Settings > API)
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Secret key to secure your Google Pub/Sub Webhook endpoint (make up a strong random string)
# The webhook URL will be: https://your-cloud-run-url.a.run.app/webhook/pubsub?secret=your-pubsub-secret
PUBSUB_SECRET=some-long-random-string-for-security
